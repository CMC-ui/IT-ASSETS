@inherits LayoutComponentBase

<div class="page">
    <div class="sidebar">
        <NavMenu />
    </div>

    <main class="w-100">
        <div class="px-4 pt-3 d-none d-sm-block">
            <button class="btn btn-outline-secondary border-0" onclick="toggleSidebar()" title="Toggle Menu">
                <i class="bi bi-list fs-5"></i>
            </button>
        </div>
        <article class="content px-4">
            @Body
        </article>
    </main>
</div>

<div id="blazor-error-ui" data-nosnippet>
    An unhandled error has occurred.
    <a href="." class="reload">Reload</a>
    <span class="dismiss">🗙</span>
</div>

