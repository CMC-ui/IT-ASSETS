<div class="top-row ps-3 navbar navbar-dark">
    <div class="container-fluid">
        <a class="navbar-brand d-flex align-items-center" href="">
            <img src="favicon.png" alt="Logo" style="height: 24px; margin-right: 10px;" />
            IT ASSETS
        </a>
    </div>
</div>

<input type="checkbox" title="Navigation menu" class="navbar-toggler" />

<div class="nav-scrollable" onclick="document.querySelector('.navbar-toggler').click()">
    <nav class="nav flex-column">
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="" Match="NavLinkMatch.All">
                <span class="bi bi-laptop-nav-menu" aria-hidden="true"></span> Assets
            </NavLink>
        </div>

        <div class="nav-item px-3">
            <NavLink class="nav-link" href="users">
                <span class="bi bi-people-fill-nav-menu" aria-hidden="true"></span> Users
            </NavLink>
        </div>

        <AuthorizeView Roles="Admin">
            <div class="nav-item px-3">
                <NavLink class="nav-link" href="import">
                    <span class="bi bi-upload-nav-menu" aria-hidden="true"></span> Bulk Import
                </NavLink>
            </div>
        </AuthorizeView>

        <div class="mt-auto pt-3 border-top border-secondary">
            <AuthorizeView Context="authContext">
                <Authorized>
                    <div class="nav-item px-3">
                        <form method="post" action="Identity/Account/Logout?returnUrl=/Identity/Account/Login">
                            <AntiforgeryToken />
                            <button type="submit" class="nav-link btn btn-link w-100 text-start">
                                <span class="bi bi-box-arrow-right-nav-menu" aria-hidden="true"></span> Logout
                            </button>
                        </form>
                    </div>
                </Authorized>
                <NotAuthorized>
                    <div class="nav-item px-3">
                        <NavLink class="nav-link" href="Identity/Account/Login">
                            <span class="bi bi-box-arrow-in-right-nav-menu" aria-hidden="true"></span> Login
                        </NavLink>
                    </div>
                </NotAuthorized>
            </AuthorizeView>

            <div class="nav-item px-4 mt-2 mb-3 d-flex flex-column">
                <span style="color: #d7d7d7; font-size: 0.9rem; margin-bottom: 5px;"><i class="bi bi-palette-fill text-info me-2"></i>Theme</span>
                <select id="themeSelect" class="form-select form-select-sm bg-transparent text-white border-secondary" onchange="changeTheme(this.value)">
                    <option value="light" style="color: black;">☀️ Light</option>
                    <option value="dark" style="color: black;">🌙 Dark</option>
                    <option value="matrix" style="color: black;">👾 Matrix</option>
                </select>
            </div>
        </div>
    </nav>
</div>

