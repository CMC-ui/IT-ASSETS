@page "/"
@page "/assets"
@rendermode InteractiveServer
@using ItAssets.Data
@using ItAssets.Models
@using Microsoft.EntityFrameworkCore
@using QRCoder
@inject ApplicationDbContext DbContext
@inject NavigationManager NavManager
@inject IJSRuntime JSRuntime
@inject ItAssets.Services.HandoverPdfService HandoverPdfService

<PageTitle>Assets</PageTitle>

<div class="card shadow-sm">
    <div class="card-body">
        <div class="row mb-3">
            <div class="col-md-6 d-flex">
                <input type="text" class="form-control me-2" placeholder="Search by Asset Tag, SN, IP, or User..." @bind="SearchQuery" @bind:event="oninput" @onkeyup="FilterAssets" />
                <div class="btn-group" role="group">
                    <input type="radio" class="btn-check" name="viewToggle" id="listView" autocomplete="off" checked="@(!IsCardView)" @onchange="@(() => IsCardView = false)">
                    <label class="btn btn-outline-secondary" for="listView"><i class="bi bi-list-ul"></i></label>

                    <input type="radio" class="btn-check" name="viewToggle" id="cardView" autocomplete="off" checked="@IsCardView" @onchange="@(() => IsCardView = true)">
                    <label class="btn btn-outline-secondary" for="cardView"><i class="bi bi-grid"></i></label>
                </div>
                <button class="btn btn-outline-secondary shadow-sm" @onclick='() => OpenScannerModal("GlobalSearch")'>
            <i class="bi bi-upc-scan"></i> Scan QR
        </button>
            </div>
            <div class="col-md-6 text-end">
                <button class="btn btn-primary shadow-sm" @onclick="OpenAddModal">
                    <i class="bi bi-plus-circle"></i> Add Asset
                </button>
            </div>
        </div>

        @if (!IsCardView)
        {
            <div class="table-responsive">
                <table class="table table-hover align-middle">
                <thead style="background-color: var(--bs-tertiary-bg); color: var(--bs-primary);">
                    <tr>
                        <th>Asset Tag</th>
                        <th>Type</th>
                        <th>Make/Model</th>
                        <th>IP Address</th>
                        <th>Branch</th>
                        <th>Dept</th>
                        <th>User</th>
                        <th>Status</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @if (FilteredAssets == null)
                    {
                        <tr><td colspan="9" class="text-center">Loading...</td></tr>
                    }
                    else if (!FilteredAssets.Any())
                    {
                        <tr><td colspan="9" class="text-center">No assets found.</td></tr>
                    }
                    else
                    {
                        @foreach (var asset in FilteredAssets)
                        {
                            <tr>
                                <td><strong>@asset.AssetTag</strong></td>
                                <td>@asset.DeviceType</td>
                                <td>@asset.MakeModel</td>
                                <td>@asset.IpAddress</td>
                                <td>@asset.Branch?.Name</td>
                                <td>@asset.Department?.Name</td>
                                <td>@asset.User?.Name</td>
                                <td>
                                    <span class="badge @GetStatusBadgeClass(asset.Status)">@asset.Status</span>
                                </td>
                                <td>
                                    <button class="btn btn-sm btn-outline-primary me-1" @onclick="() => OpenModal(asset)">
                                        <i class="bi bi-pencil"></i> Manage
                                    </button>
                                    <button class="btn btn-sm btn-outline-secondary me-1" @onclick="() => OpenPrintModal(asset)">
                                        <i class="bi bi-printer"></i> Print QR
                                    </button>
                                    <button class="btn btn-sm btn-outline-danger" @onclick="() => DeleteAsset(asset)">
                                        <i class="bi bi-trash"></i> Delete
                                    </button>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
        }
        else
        {
            <div class="row g-3">
                @if (FilteredAssets == null)
                {
                    <div class="col-12 text-center">Loading...</div>
                }
                else if (!FilteredAssets.Any())
                {
                    <div class="col-12 text-center">No assets found.</div>
                }
                else
                {
                    @foreach (var asset in FilteredAssets)
                    {
                        <div class="col-md-4 col-sm-6">
                            <div class="card h-100 shadow-sm border-0">
                                <div class="card-body position-relative">
                                    <div class="d-flex justify-content-between align-items-start mb-2">
                                        <h5 class="card-title fw-bold mb-0">@asset.AssetTag</h5>
                                        <span class="badge @GetStatusBadgeClass(asset.Status)">@asset.Status</span>
                                    </div>
                                    <h6 class="card-subtitle mb-2 text-muted">@asset.DeviceType</h6>
                                    <hr class="my-2" />
                                    <p class="card-text small mb-1"><strong>Make/Model:</strong> @asset.MakeModel</p>
                                    <p class="card-text small mb-1"><strong>IP:</strong> @asset.IpAddress</p>
                                    <p class="card-text small mb-1"><strong>User:</strong> @asset.User?.Name</p>
                                    <p class="card-text small mb-3"><strong>Location:</strong> @asset.Branch?.Name - @asset.Department?.Name</p>
                                </div>
                                <div class="card-footer bg-transparent border-top-0 d-flex justify-content-between pb-3 px-3">
                                    <button class="btn btn-sm btn-outline-primary" @onclick="() => OpenModal(asset)">
                                        <i class="bi bi-pencil"></i> Manage
                                    </button>
                                    <button class="btn btn-sm btn-outline-secondary" @onclick="() => OpenPrintModal(asset)">
                                        <i class="bi bi-printer"></i> Print QR
                                    </button>
                                    <button class="btn btn-sm btn-outline-danger" @onclick="() => DeleteAsset(asset)">
                                        <i class="bi bi-trash"></i> Delete
                                    </button>
                                </div>
                            </div>
                        </div>
                    }
                }
            </div>
        }
    </div>
</div>

@if (SelectedAsset != null)
{
    <div id="printAssetData" class="d-none">
        <h2 class="mb-4">Asset Details: @SelectedAsset.AssetTag</h2>
        <table class="table table-bordered table-striped">
            <tbody>
                <tr><th style="width: 30%">Device Type</th><td>@SelectedAsset.DeviceType</td></tr>
                <tr><th>Make/Model</th><td>@SelectedAsset.MakeModel</td></tr>
                <tr><th>Serial Number</th><td>@SelectedAsset.SerialNumber</td></tr>
                <tr><th>Status</th><td>@SelectedAsset.Status</td></tr>
                <tr><th>MAC Address</th><td>@SelectedAsset.MacAddress</td></tr>
                <tr><th>IP Address</th><td>@SelectedAsset.IpAddress</td></tr>
                <tr><th>Purchase Price</th><td>@SelectedAsset.PurchasePrice.ToString("C", new System.Globalization.CultureInfo("en-ZA"))</td></tr>
                <tr><th>Warranty Expiration</th><td>@SelectedAsset.WarrantyExpiration?.ToString("yyyy-MM-dd")</td></tr>
                <tr><th>Hardware Specs</th><td>@SelectedAssetSpecs</td></tr>
                <tr><th>RUST DESK ID</th><td>@SelectedAssetRustDesk</td></tr>
                <tr><th>AnyDesk ID</th><td>@SelectedAssetAnyDesk</td></tr>
                <tr><th>Supplier</th><td>@SelectedAsset.Supplier</td></tr>
                <tr><th>Date Received</th><td>@SelectedAsset.DateReceived?.ToString("yyyy-MM-dd")</td></tr>
                <tr><th>Branch</th><td>@(AllBranches?.FirstOrDefault(b => b.Id == SelectedAsset.BranchId)?.Name)</td></tr>
                <tr><th>Department</th><td>@(AllDepartments?.FirstOrDefault(d => d.Id == SelectedAsset.DepartmentId)?.Name)</td></tr>
                <tr><th>Assigned User</th><td>@(AllUsers?.FirstOrDefault(u => u.Id == SelectedAsset.UserId)?.Name)</td></tr>
                <tr><th>Notes</th><td>@SelectedAsset.Notes</td></tr>
            </tbody>
        </table>

        @if (SelectedAsset.Documents != null && SelectedAsset.Documents.Any())
        {
            <h4 class="mt-4 mb-3">Attached Documents/Images</h4>
            <div class="row">
                @foreach (var doc in SelectedAsset.Documents)
                {
                    <div class="col-6 mb-4 text-center">
                        <p class="mb-2 fw-bold text-truncate">@doc.FileName</p>
                        @if (doc.FilePath.EndsWith(".pdf", StringComparison.OrdinalIgnoreCase))
                        {
                            <div class="p-4 border rounded bg-light">[PDF Document - Not rendered in print view]</div>
                        }
                        else
                        {
                            <img src="/uploads/@doc.FilePath" class="img-fluid border rounded" style="max-height: 250px; object-fit: contain;" />
                        }
                    </div>
                }
            </div>
        }
    </div>
    <!-- Quick Manage Modal -->
    <div class="modal fade show d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.5);">
        <div class="modal-dialog modal-lg">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Manage Asset @SelectedAsset.AssetTag</h5>
                    <button type="button" class="btn-close" @onclick="CloseModal"></button>
                </div>
                <div class="modal-body">
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Asset Tag <span class="text-muted">(Auto-generated)</span></label>
                            <input type="text" class="form-control" @bind="SelectedAsset.AssetTag" readonly disabled />
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Device Type</label>
                            <input type="text" class="form-control" @bind="SelectedAsset.DeviceType" />
                        </div>
                    </div>
                    <div class="row">
                        <div class="col-md-4 mb-3">
                            <label class="form-label">Make/Model</label>
                            <input type="text" class="form-control" @bind="SelectedAsset.MakeModel" />
                        </div>
                        <div class="col-md-4 mb-3">
                            <label class="form-label">Serial Number</label>
                            <input type="text" class="form-control" @bind="SelectedAsset.SerialNumber" />
                        </div>
                        <div class="col-md-4 mb-3">
                            <label class="form-label">Status</label>
                            <select class="form-select" @bind="SelectedAsset.Status">
                                <option value="Active">Active</option>
                                <option value="In Repair">In Repair</option>
                                <option value="Decommissioned">Decommissioned</option>
                                <option value="Stock">Stock</option>
                            </select>
                        </div>
                    </div>
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Supplier</label>
                            <input type="text" class="form-control" @bind="SelectedAsset.Supplier" />
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Date Received</label>
                            <input type="date" class="form-control" @bind="SelectedAsset.DateReceived" />
                        </div>
                    </div>
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label">MAC Address</label>
                            <input type="text" class="form-control" @bind="SelectedAsset.MacAddress" />
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label">IP Address</label>
                            <input type="text" class="form-control" @bind="SelectedAsset.IpAddress" />
                        </div>
                    </div>
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Branch</label>
                            <select class="form-select" @bind="SelectedAsset.BranchId">
                                <option value="">-- Select Branch --</option>
                                @if (AllBranches != null)
                                {
                                    @foreach (var b in AllBranches)
                                    {
                                        <option value="@b.Id">@b.Name</option>
                                    }
                                }
                            </select>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Department</label>
                            <select class="form-select" @bind="SelectedAsset.DepartmentId">
                                <option value="">-- Select Department --</option>
                                @if (AllDepartments != null)
                                {
                                    @foreach (var d in AllDepartments)
                                    {
                                        <option value="@d.Id">@d.Name</option>
                                    }
                                }
                            </select>
                        </div>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Assigned User</label>
                        <select class="form-select" @bind="SelectedAsset.UserId">
                            <option value="">-- Unassigned --</option>
                            @if (AllUsers != null)
                            {
                                @foreach (var user in AllUsers)
                                {
                                    <option value="@user.Id">@user.Name (@user.Email)</option>
                                }
                            }
                        </select>
                        <div class="form-check form-switch mt-2 d-flex justify-content-between align-items-center">
                            <div>
                                <input class="form-check-input" type="checkbox" role="switch" id="manageSignedHandover" @bind="SelectedAsset.UserSignedHandover">
                                <label class="form-check-label" for="manageSignedHandover">User Signed Handover (Yes/No)</label>
                            </div>
                            @if (!string.IsNullOrEmpty(SelectedAsset.UserId))
                            {
                                <button type="button" class="btn btn-sm btn-outline-success" @onclick="OpenSignatureModal">
                                    <i class="bi bi-pen"></i> Generate Handover
                                </button>
                            }
                        </div>
                    </div>
                    <div class="row">
                        <div class="col-md-4 mb-3">
                            <label class="form-label">Purchase Price</label>
                            <div class="input-group">
                                <span class="input-group-text">R</span>
                                <input type="number" step="0.01" class="form-control" @bind="SelectedAsset.PurchasePrice" />
                            </div>
                        </div>
                        <div class="col-md-4 mb-3">
                            <label class="form-label">Payment Method</label>
                            <select class="form-select" @bind="SelectedAsset.PaymentMethod">
                                <option value="">-- Select --</option>
                                <option value="EFT">EFT</option>
                                <option value="CREDIT CARD">CREDIT CARD</option>
                                <option value="CASH">CASH</option>
                                <option value="DEBIT ORDER">DEBIT ORDER</option>
                            </select>
                        </div>
                        <div class="col-md-4 mb-3">
                            <label class="form-label">Warranty Expiration</label>
                            <input type="date" class="form-control" @bind="SelectedAsset.WarrantyExpiration" />
                        </div>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Hardware Specs</label>
                        <textarea class="form-control" rows="2" placeholder="e.g. 16GB RAM, 512GB SSD, i7 CPU" @bind="SelectedAssetSpecs"></textarea>
                    </div>
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label">RUST DESK ID</label>
                            <input type="text" class="form-control" @bind="SelectedAssetRustDesk" />
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label">AnyDesk ID</label>
                            <input type="text" class="form-control" @bind="SelectedAssetAnyDesk" />
                        </div>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">NOTES</label>
                        <textarea class="form-control" rows="2" placeholder="Enter notes here..." @bind="SelectedAsset.Notes"></textarea>
                    </div>
                    
                    @if (SelectedAsset.Status == "In Repair")
                    {
                        <div class="mb-3">
                            <label class="form-label text-warning"><i class="bi bi-exclamation-triangle"></i> Maintenance Note</label>
                            <textarea class="form-control" @bind="MaintenanceNote" placeholder="Describe the issue..."></textarea>
                        </div>
                    }
                    <div class="mb-3">
                        <label class="form-label">Upload Documents/Images (Max 10MB each)</label>
                        <div class="d-flex gap-2 mb-2">
                            <label class="btn btn-outline-primary w-50 m-0">
                                <i class="bi bi-camera"></i> Take Photo
                                <InputFile OnChange="@AppendFiles" accept="image/*" capture="environment" multiple hidden />
                            </label>
                            <label class="btn btn-outline-secondary w-50 m-0">
                                <i class="bi bi-folder2-open"></i> Browse Files
                                <InputFile OnChange="@AppendFiles" accept=".pdf,.png,.jpg,.jpeg,image/*" multiple hidden />
                            </label>
                        </div>
                        @if (uploadedFiles.Any())
                        {
                            <div class="d-flex justify-content-between align-items-center bg-light p-2 rounded border">
                                <small class="text-success fw-bold"><i class="bi bi-check-circle"></i> Ready to upload @uploadedFiles.Count files</small>
                                <button type="button" class="btn btn-sm btn-outline-danger py-0" @onclick="ClearFiles">Clear</button>
                            </div>
                            <ul class="list-unstyled mt-2 small mb-0">
                                @foreach(var f in uploadedFiles)
                                {
                                    <li><i class="bi bi-file-earmark text-muted"></i> @f.Name</li>
                                }
                            </ul>
                        }
                        
                        @if (SelectedAsset.Documents != null && SelectedAsset.Documents.Any())
                        {
                            <div class="row mt-4">
                                @foreach (var doc in SelectedAsset.Documents.ToList())
                                {
                                    <div class="col-md-6 mb-3 position-relative">
                                        <div class="d-flex justify-content-between align-items-center mb-1">
                                            <label class="form-label text-muted fw-bold mb-0 text-truncate" style="max-width: 70%;">@doc.FileName</label>
                                            <div>
                                                <a href="/uploads/@doc.FilePath" target="_blank" class="btn btn-sm btn-outline-primary me-1" title="View / Print">
                                                    <i class="bi bi-box-arrow-up-right"></i>
                                                </a>
                                                <button type="button" class="btn btn-sm btn-outline-danger" @onclick="() => DeleteDocument(doc)" title="Delete">
                                                    <i class="bi bi-trash"></i>
                                                </button>
                                            </div>
                                        </div>
                                        @if (doc.FilePath.EndsWith(".pdf", StringComparison.OrdinalIgnoreCase))
                                        {
                                            <embed src="/uploads/@doc.FilePath" type="application/pdf" width="100%" height="250px" class="border rounded shadow-sm" />
                                        }
                                        else
                                        {
                                            <div class="bg-body-secondary border rounded shadow-sm p-2 d-flex align-items-center justify-content-center" style="height: 250px;">
                                                <img src="/uploads/@doc.FilePath" class="img-fluid rounded" style="max-height: 100%; object-fit: contain;" />
                                            </div>
                                        }
                                    </div>
                                }
                            </div>
                        }
                    </div>
                </div>
                <div class="modal-footer d-flex justify-content-between">
                    <div>
                        <button type="button" class="btn btn-outline-danger" @onclick="() => DeleteAsset(SelectedAsset)">
                            <i class="bi bi-trash"></i> Delete
                        </button>
                    </div>
                    <div>
                        <button type="button" class="btn btn-outline-secondary me-2" @onclick="PrintManageModal"><i class="bi bi-printer"></i> Print</button>
                        <button type="button" class="btn btn-secondary me-2" @onclick="CloseModal">Close</button>
                        <button type="button" class="btn btn-primary" @onclick="SaveChanges">Save changes</button>
                    </div>
                </div>
            </div>
        </div>
    </div>
}

@if (NewAsset != null)
{
    <!-- Add Asset Modal -->
    <div class="modal fade show d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.5);">
        <div class="modal-dialog modal-lg">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Add New Asset</h5>
                    <button type="button" class="btn-close" @onclick="CloseAddModal"></button>
                </div>
                <div class="modal-body">
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Asset Tag</label>
                            <div class="input-group">
                                <input type="text" class="form-control" @bind="NewAsset.AssetTag" />
                                <button class="btn btn-outline-secondary" type="button" @onclick='() => OpenScannerModal("AssetTag")'><i class="bi bi-upc-scan"></i></button>
                            </div>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Device Type</label>
                            <input type="text" class="form-control" @bind="NewAsset.DeviceType" />
                        </div>
                    </div>
                    <div class="row">
                        <div class="col-md-4 mb-3">
                            <label class="form-label">Make/Model</label>
                            <input type="text" class="form-control" @bind="NewAsset.MakeModel" />
                        </div>
                        <div class="col-md-4 mb-3">
                            <label class="form-label">Serial Number</label>
                            <div class="input-group">
                                <input type="text" class="form-control" @bind="NewAsset.SerialNumber" />
                                <button class="btn btn-outline-secondary" type="button" @onclick='() => OpenScannerModal("SerialNumber")'><i class="bi bi-upc-scan"></i></button>
                            </div>
                        </div>
                        <div class="col-md-4 mb-3">
                            <label class="form-label">Status</label>
                            <select class="form-select" @bind="NewAsset.Status">
                                <option value="Active">Active</option>
                                <option value="In Repair">In Repair</option>
                                <option value="Decommissioned">Decommissioned</option>
                                <option value="Stock">Stock</option>
                            </select>
                        </div>
                    </div>
                    
                    <div class="mb-3">
                        <label class="form-label">Assigned User</label>
                        <select class="form-select" @bind="NewAsset.UserId">
                            <option value="">-- Unassigned --</option>
                            @if (AllUsers != null)
                            {
                                @foreach (var user in AllUsers)
                                {
                                    <option value="@user.Id">@user.Name (@user.Email)</option>
                                }
                            }
                        </select>
                        <div class="form-check form-switch mt-2">
                            <input class="form-check-input" type="checkbox" role="switch" id="addSignedHandover" @bind="NewAsset.UserSignedHandover">
                            <label class="form-check-label" for="addSignedHandover">User Signed Handover (Yes/No)</label>
                        </div>
                    </div>
                    
                    <div class="accordion mb-3" id="addAssetAccordion">
                        <div class="accordion-item">
                            <h2 class="accordion-header">
                                <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#collapseMoreDetails">
                                    More Details (Optional)
                                </button>
                            </h2>
                            <div id="collapseMoreDetails" class="accordion-collapse collapse" data-bs-parent="#addAssetAccordion">
                                <div class="accordion-body">
                                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Supplier</label>
                            <input type="text" class="form-control" @bind="NewAsset.Supplier" />
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Date Received</label>
                            <input type="date" class="form-control" @bind="NewAsset.DateReceived" />
                        </div>
                    </div>
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label">MAC Address</label>
                            <input type="text" class="form-control" @bind="NewAsset.MacAddress" />
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label">IP Address</label>
                            <input type="text" class="form-control" @bind="NewAsset.IpAddress" />
                        </div>
                    </div>
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Branch</label>
                            <select class="form-select" @bind="NewAsset.BranchId">
                                <option value="">-- Select Branch --</option>
                                @if (AllBranches != null)
                                {
                                    @foreach (var b in AllBranches)
                                    {
                                        <option value="@b.Id">@b.Name</option>
                                    }
                                }
                            </select>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Department</label>
                            <select class="form-select" @bind="NewAsset.DepartmentId">
                                <option value="">-- Select Department --</option>
                                @if (AllDepartments != null)
                                {
                                    @foreach (var d in AllDepartments)
                                    {
                                        <option value="@d.Id">@d.Name</option>
                                    }
                                }
                            </select>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-4 mb-3">
                            <label class="form-label">Purchase Price</label>
                            <div class="input-group">
                                <span class="input-group-text">R</span>
                                <input type="number" step="0.01" class="form-control" @bind="NewAsset.PurchasePrice" />
                            </div>
                        </div>
                        <div class="col-md-4 mb-3">
                            <label class="form-label">Payment Method</label>
                            <select class="form-select" @bind="NewAsset.PaymentMethod">
                                <option value="">-- Select --</option>
                                <option value="EFT">EFT</option>
                                <option value="CREDIT CARD">CREDIT CARD</option>
                                <option value="CASH">CASH</option>
                                <option value="DEBIT ORDER">DEBIT ORDER</option>
                            </select>
                        </div>
                        <div class="col-md-4 mb-3">
                            <label class="form-label">Warranty Expiration</label>
                            <input type="date" class="form-control" @bind="NewAsset.WarrantyExpiration" />
                        </div>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Hardware Specs</label>
                        <textarea class="form-control" rows="2" placeholder="e.g. 16GB RAM, 512GB SSD, i7 CPU" @bind="NewAssetSpecs"></textarea>
                    </div>
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label">RUST DESK ID</label>
                            <input type="text" class="form-control" @bind="NewAssetRustDesk" />
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label">AnyDesk ID</label>
                            <input type="text" class="form-control" @bind="NewAssetAnyDesk" />
                        </div>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">NOTES</label>
                        <textarea class="form-control" rows="2" placeholder="Enter notes here..." @bind="NewAsset.Notes"></textarea>
                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Upload Documents/Images (Max 10MB each)</label>
                        <div class="d-flex gap-2 mb-2">
                            <label class="btn btn-outline-primary w-50 m-0">
                                <i class="bi bi-camera"></i> Take Photo
                                <InputFile OnChange="@AppendFiles" accept="image/*" capture="environment" multiple hidden />
                            </label>
                            <label class="btn btn-outline-secondary w-50 m-0">
                                <i class="bi bi-folder2-open"></i> Browse Files
                                <InputFile OnChange="@AppendFiles" accept=".pdf,.png,.jpg,.jpeg,image/*" multiple hidden />
                            </label>
                        </div>
                        @if (uploadedFiles.Any())
                        {
                            <div class="d-flex justify-content-between align-items-center bg-light p-2 rounded border">
                                <small class="text-success fw-bold"><i class="bi bi-check-circle"></i> Ready to upload @uploadedFiles.Count files</small>
                                <button type="button" class="btn btn-sm btn-outline-danger py-0" @onclick="ClearFiles">Clear</button>
                            </div>
                            <ul class="list-unstyled mt-2 small mb-0">
                                @foreach(var f in uploadedFiles)
                                {
                                    <li><i class="bi bi-file-earmark text-muted"></i> @f.Name</li>
                                }
                            </ul>
                        }
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" @onclick="CloseAddModal">Cancel</button>
                    <button type="button" class="btn btn-outline-primary" @onclick="() => SaveNewAsset(true)">Save & Add Next</button>
                    <button type="button" class="btn btn-primary" @onclick="() => SaveNewAsset(false)">Save</button>
                </div>
            </div>
        </div>
    </div>
}

@if (AssetToPrint != null)
{
