@code {
    [Inject] private ItAssets.Services.FileStorageService FileStorage { get; set; } = default!;

    private bool IsCardView = false;
    private List<Asset>? AllAssets;
    private List<Asset>? FilteredAssets;
    private List<ApplicationUser>? AllUsers;
    private List<Branch>? AllBranches;
    private List<Department>? AllDepartments;

    [SupplyParameterFromQuery(Name = "search")]
    public string? SearchQueryParam { get; set; }

    private string SearchQuery = "";
    private Asset? SelectedAsset;
    private Asset? NewAsset;
    private string NewAssetSpecs = "";
    private string NewAssetRustDesk = "";
    private string NewAssetAnyDesk = "";
    private string MaintenanceNote = "";
    private class TempFile
    {
        public string Name { get; set; } = string.Empty;
        public string SavedPath { get; set; } = string.Empty;
    }
    private List<TempFile> uploadedFiles = new List<TempFile>();

    protected override async Task OnInitializedAsync()
    {
        if (!string.IsNullOrWhiteSpace(SearchQueryParam))
        {
            SearchQuery = SearchQueryParam;
            IsCardView = true; // Use card view for mobile scans
        }
        await LoadAssets();
        
        if (!string.IsNullOrWhiteSpace(SearchQueryParam) && FilteredAssets != null && FilteredAssets.Count == 1)
        {
            OpenModal(FilteredAssets.First());
            SearchQueryParam = null; // clear to prevent reopening on re-renders
        }
    }

    private async Task LoadAssets()
    {
        AllAssets = await DbContext.Assets
            .Include(a => a.User)
            .Include(a => a.Documents)
            .OrderByDescending(a => a.Id)
            .ToListAsync();
        
        AllUsers = await DbContext.Users.ToListAsync();
        AllBranches = await DbContext.Branches.ToListAsync();
        AllDepartments = await DbContext.Departments.ToListAsync();
        
        FilterAssets();
    }

    private void FilterAssets()
    {
        if (AllAssets == null) return;

        if (string.IsNullOrWhiteSpace(SearchQuery))
        {
            FilteredAssets = AllAssets;
        }
        else
        {
            var q = SearchQuery.ToLower();
            FilteredAssets = AllAssets.Where(a => 
                a.AssetTag.ToLower().Contains(q) || 
                a.IpAddress.ToLower().Contains(q) || 
                a.SerialNumber.ToLower().Contains(q) ||
                (a.User != null && a.User.Name.ToLower().Contains(q))
            ).ToList();
        }
    }

    private string ExtractDetail(string json, string key)
    {
        try
        {
            if (string.IsNullOrWhiteSpace(json)) return "";
            using var doc = System.Text.Json.JsonDocument.Parse(json);
            if (doc.RootElement.TryGetProperty(key, out var prop))
            {
                return prop.GetString() ?? "";
            }
        }
        catch { }
        return "";
    }

    private string GetStatusBadgeClass(string status)
    {
        return status switch
        {
            "Active" => "bg-success",
            "In Repair" => "bg-warning text-dark",
            "Decommissioned" => "bg-danger",
            _ => "bg-secondary"
        };
    }

    private string SelectedAssetSpecs = "";
    private string SelectedAssetRustDesk = "";
    private string SelectedAssetAnyDesk = "";

    private void OpenModal(Asset asset)
    {
        SelectedAsset = asset;
        SelectedAssetSpecs = ExtractDetail(asset.Details, "Specs");
        SelectedAssetRustDesk = ExtractDetail(asset.Details, "RustDeskId");
        SelectedAssetAnyDesk = ExtractDetail(asset.Details, "AnyDeskId");
    }

    private void CloseModal()
    {
        SelectedAsset = null;
        ClearFiles();
    }

    private async Task OpenAddModal()
    {
        string nextTag = "AST-0001";
        
        var astAssets = await DbContext.Assets
            .Where(a => a.AssetTag.StartsWith("AST-"))
            .ToListAsync();
            
        if (astAssets.Any())
        {
            int maxNumber = 0;
            foreach(var a in astAssets)
            {
                if (a.AssetTag.Length >= 8 && int.TryParse(a.AssetTag.Substring(4), out int num))
                {
                    if (num > maxNumber) maxNumber = num;
                }
            }
            if (maxNumber > 0)
            {
                nextTag = $"AST-{(maxNumber + 1):D4}";
            }
        }
        
        NewAsset = new Asset { Status = "Active", AssetTag = nextTag };
    }

    private void CloseAddModal()
    {
        NewAsset = null;
        ClearFiles();
    }

    private Asset? AssetToPrint;
    private string QRBase64 = "";

    private void OpenPrintModal(Asset asset)
    {
        AssetToPrint = asset;
        var appUrl = NavManager.ToAbsoluteUri($"/assets?search={asset.AssetTag}").ToString();
        QRBase64 = GenerateQRCodeBase64(appUrl);
    }

    private void ClosePrintModal()
    {
        AssetToPrint = null;
        QRBase64 = "";
    }

    private async Task ShareQRCodeEmail()
    {
        if (AssetToPrint == null || string.IsNullOrEmpty(QRBase64)) return;

        var subject = $"Print QR Code for Asset {AssetToPrint.AssetTag}";
        var body = $"Please find the attached QR code to be printed for Asset Tag: {AssetToPrint.AssetTag}\r\nMake/Model: {AssetToPrint.MakeModel}\r\nSN: {AssetToPrint.SerialNumber}";
        var toEmail = "diamondcards@cmcglobal.co.za";
        var filename = $"QRCode_{AssetToPrint.AssetTag}.png";

        await JSRuntime.InvokeVoidAsync("qrShare.shareImage", QRBase64, filename, toEmail, subject, body);
    }

    private async Task PrintManageModal()
    {
        var js = @"
            var printContents = document.getElementById('printAssetData').innerHTML;
            var myWindow = window.open('', '', 'width=800,height=800');
            myWindow.document.write('<html><head><title>Print Asset</title>');
            myWindow.document.write('<base href=""' + window.location.origin + '"">');
            myWindow.document.write('<link href=""/lib/bootstrap/dist/css/bootstrap.min.css"" rel=""stylesheet"">');
            myWindow.document.write('<style>body{padding:40px; font-family: sans-serif;}</style>');
            myWindow.document.write('</head><body>');
            myWindow.document.write(printContents);
            myWindow.document.write('<script>setTimeout(function(){ window.print(); window.close(); }, 500);</script>');
            myWindow.document.write('</body></html>');
            myWindow.document.close();
            myWindow.focus();
        ";
        await JSRuntime.InvokeVoidAsync("eval", js);
    }

    private string GenerateQRCodeBase64(string text)
    {
        using QRCodeGenerator qrGenerator = new QRCodeGenerator();
        using QRCodeData qrCodeData = qrGenerator.CreateQrCode(text, QRCodeGenerator.ECCLevel.Q);
        using PngByteQRCode qrCode = new PngByteQRCode(qrCodeData);
        byte[] qrCodeImage = qrCode.GetGraphic(20);
        return Convert.ToBase64String(qrCodeImage);
    }

    private async Task SaveNewAsset(bool keepOpen = false)
    {
        if (NewAsset != null && !string.IsNullOrWhiteSpace(NewAsset.AssetTag))
        {
            if (!string.IsNullOrWhiteSpace(NewAssetSpecs) || !string.IsNullOrWhiteSpace(NewAssetRustDesk) || !string.IsNullOrWhiteSpace(NewAssetAnyDesk))
            {
                NewAsset.Details = System.Text.Json.JsonSerializer.Serialize(new 
                { 
                    Specs = NewAssetSpecs,
                    RustDeskId = NewAssetRustDesk,
                    AnyDeskId = NewAssetAnyDesk
                });
            }

            DbContext.Assets.Add(NewAsset);
            await DbContext.SaveChangesAsync();
            
            if (uploadedFiles.Any())
            {
                foreach(var file in uploadedFiles)
                {
                    DbContext.AssetDocuments.Add(new AssetDocument
                    {
                        AssetId = NewAsset.Id,
                        FileName = file.Name,
                        FilePath = file.SavedPath,
                        DocumentType = "Document"
                    });
                }
                await DbContext.SaveChangesAsync();
            }

            await LoadAssets();
            
            if (keepOpen)
            {
                // Reset unique fields for next capture
                string nextTag = $"AST-{new Random().Next(10000, 99999)}";
                var astAssets = DbContext.Assets.Where(a => a.AssetTag.StartsWith("AST-")).ToList();
                if (astAssets.Any())
                {
                    int maxNumber = 0;
                    foreach(var a in astAssets)
                    {
                        if (a.AssetTag.Length >= 8 && int.TryParse(a.AssetTag.Substring(4), out int num))
                        {
                            if (num > maxNumber) maxNumber = num;
                        }
                    }
                    if (maxNumber > 0) nextTag = $"AST-{(maxNumber + 1):D4}";
                }

                var newAsset = new Asset 
                { 
                    AssetTag = nextTag,
                    Status = NewAsset.Status,
                    DeviceType = NewAsset.DeviceType,
                    MakeModel = NewAsset.MakeModel,
                    Supplier = NewAsset.Supplier,
                    BranchId = NewAsset.BranchId,
                    DepartmentId = NewAsset.DepartmentId,
                    DateReceived = NewAsset.DateReceived,
                    PurchasePrice = NewAsset.PurchasePrice
                };
                
                NewAsset = newAsset;
                NewAssetSpecs = "";
                NewAssetRustDesk = "";
                NewAssetAnyDesk = "";
                uploadedFiles = new List<TempFile>();
            }
            else
            {
                NewAsset = null;
                NewAssetSpecs = "";
                NewAssetRustDesk = "";
                NewAssetAnyDesk = "";
                uploadedFiles = new List<TempFile>();
            }
        }
    }

    private async Task AppendFiles(InputFileChangeEventArgs e)
    {
        var maxAllowedSize = 10 * 1024 * 1024; // 10 MB
        foreach (var file in e.GetMultipleFiles(10))
        {
            if (file.Size <= maxAllowedSize)
            {
                try
                {
                    var relativePath = await FileStorage.SaveFileAsync(file);
                    if (!string.IsNullOrEmpty(relativePath))
                    {
                        uploadedFiles.Add(new TempFile { Name = file.Name, SavedPath = relativePath });
                    }
                }
                catch { }
            }
        }
    }

    private void ClearFiles()
    {
        foreach(var f in uploadedFiles)
        {
            FileStorage.DeleteFile(f.SavedPath);
        }
        uploadedFiles.Clear();
    }

    private async Task DeleteDocument(AssetDocument doc)
    {
        DbContext.AssetDocuments.Remove(doc);
        await DbContext.SaveChangesAsync();
        SelectedAsset?.Documents.Remove(doc);
    }

    private async Task SaveChanges()
    {
        if (SelectedAsset != null)
        {
            if (!string.IsNullOrWhiteSpace(SelectedAssetSpecs) || !string.IsNullOrWhiteSpace(SelectedAssetRustDesk) || !string.IsNullOrWhiteSpace(SelectedAssetAnyDesk))
            {
                SelectedAsset.Details = System.Text.Json.JsonSerializer.Serialize(new 
                { 
                    Specs = SelectedAssetSpecs,
                    RustDeskId = SelectedAssetRustDesk,
                    AnyDeskId = SelectedAssetAnyDesk
                });
            }

            DbContext.Assets.Update(SelectedAsset);
            
            if (SelectedAsset.Status == "In Repair" && !string.IsNullOrWhiteSpace(MaintenanceNote))
            {
                DbContext.MaintenanceLogs.Add(new MaintenanceLog
                {
                    AssetId = SelectedAsset.Id,
                    IssueDescription = MaintenanceNote,
                    Status = "Open"
                });
                MaintenanceNote = "";
            }

            await DbContext.SaveChangesAsync();

            if (uploadedFiles.Any())
            {
                foreach(var file in uploadedFiles)
                {
                    DbContext.AssetDocuments.Add(new AssetDocument
                    {
                        AssetId = SelectedAsset.Id,
                        FileName = file.Name,
                        FilePath = file.SavedPath,
                        DocumentType = "Document"
                    });
                }
                await DbContext.SaveChangesAsync();
                uploadedFiles = new List<TempFile>();
            }

            await LoadAssets();
            SelectedAsset = null;
        }
    }

    private async Task DeleteAsset(Asset asset)
    {
        bool confirmed = await JSRuntime.InvokeAsync<bool>("confirm", $"Are you sure you want to delete asset {asset.AssetTag}?");
        if (confirmed)
        {
            asset.IsDeleted = true;
            DbContext.Assets.Update(asset);
            await DbContext.SaveChangesAsync();
            await LoadAssets();
            if (SelectedAsset?.Id == asset.Id)
            {
                CloseModal();
            }
        }
    }

    private bool IsScannerOpen = false;
    private DotNetObjectReference<Index>? dotNetRef;

    private string ScannerTargetField = "GlobalSearch";

    private async Task OpenScannerModal(string target = "GlobalSearch")
    {
        ScannerTargetField = target;
        IsScannerOpen = true;
        StateHasChanged();
        await Task.Delay(100); // Give DOM time to render the modal
        dotNetRef = DotNetObjectReference.Create(this);
        try 
        {
            await JSRuntime.InvokeVoidAsync("qrScanner.start", "qr-reader", dotNetRef);
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error starting scanner: {ex.Message}");
        }
    }

    private async Task CloseScannerModal()
    {
        IsScannerOpen = false;
        try 
        {
            await JSRuntime.InvokeVoidAsync("qrScanner.stop");
        }
        catch { }
        dotNetRef?.Dispose();
    }

    [JSInvokable]
    public async Task OnQrCodeScanned(string decodedText)
    {
        await CloseScannerModal();
        
        string tag = decodedText;
        if (decodedText.Contains("search="))
        {
            tag = decodedText.Substring(decodedText.IndexOf("search=") + 7);
        }

        if (ScannerTargetField == "AssetTag" && NewAsset != null)
        {
            NewAsset.AssetTag = tag;
        }
        else if (ScannerTargetField == "SerialNumber" && NewAsset != null)
        {
            NewAsset.SerialNumber = tag;
        }
        else
        {
            SearchQuery = tag;
            IsCardView = true;
            FilterAssets();

            if (FilteredAssets != null && FilteredAssets.Count == 1)
            {
                OpenModal(FilteredAssets.First());
            }
        }
        
        StateHasChanged();
    }

    private bool IsSignatureOpen = false;
    private string SignaturePrintedName = "";

    private async Task OpenSignatureModal()
    {
        IsSignatureOpen = true;
        SignaturePrintedName = $"{SelectedAsset?.User?.Name} {SelectedAsset?.User?.Surname}".Trim();
        StateHasChanged();
        await Task.Delay(100);
        await JSRuntime.InvokeVoidAsync("signaturePad.init", "signatureCanvas");
    }

    private async Task CloseSignatureModal()
    {
        IsSignatureOpen = false;
    }

    private async Task ClearSignature()
    {
        await JSRuntime.InvokeVoidAsync("signaturePad.clear");
    }

    private async Task SaveSignatureAndGeneratePdf()
    {
        var base64Signature = await JSRuntime.InvokeAsync<string>("signaturePad.getImageData");
        
        if (SelectedAsset != null)
        {
            var pdfBytes = HandoverPdfService.GenerateHandoverPdf(SelectedAsset, base64Signature, SignaturePrintedName);
            
            var fileName = $"Handover_{SelectedAsset.AssetTag}_{DateTime.Now:yyyyMMddHHmmss}.pdf";
            var result = await FileStorage.SaveFileAsync(pdfBytes, fileName);
            if (result != null)
            {
                SelectedAsset.Documents ??= new List<AssetDocument>();
                SelectedAsset.Documents.Add(new AssetDocument
                {
                    FileName = fileName,
                    FilePath = result
                });
                
                SelectedAsset.UserSignedHandover = true;
                await SaveChanges();
            }
        }
        
        await CloseSignatureModal();
    }
}

