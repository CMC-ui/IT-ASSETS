@if (AssetToPrint != null)
{
    <!-- Print Label Modal -->
    <div class="modal fade show d-block d-print-none" tabindex="-1" style="background-color: rgba(0,0,0,0.5);">
        <div class="modal-dialog modal-sm modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Print Asset Tag</h5>
                    <button type="button" class="btn-close" @onclick="ClosePrintModal"></button>
                </div>
                <div class="modal-body text-center">
                    <img src="data:image/png;base64,@QRBase64" class="img-fluid mb-2" />
                    <h4>@AssetToPrint.AssetTag</h4>
                    <p class="text-muted mb-0">@AssetToPrint.MakeModel</p>
                </div>
                <div class="modal-footer justify-content-center">
                    <button type="button" class="btn btn-secondary" @onclick="ClosePrintModal">Close</button>
                    <a href="data:image/png;base64,@QRBase64" download="QRCode_@(AssetToPrint.AssetTag).png" class="btn btn-success">Download Image</a>
                    <button type="button" class="btn btn-primary" onclick="window.print()">Print Label</button>
                </div>
            </div>
        </div>
    </div>
    
    <!-- Printable Area (Hidden normally, shown only on print) -->
    <div class="d-none d-print-flex flex-row align-items-center justify-content-center print-container" style="width: 40mm; height: 30mm; position: absolute; top: 0; left: 0; background: white; z-index: 9999; padding: 1.5mm; box-sizing: border-box; overflow: hidden; margin: 0;">
        <img src="data:image/png;base64,@QRBase64" style="width: 26mm; height: 26mm; object-fit: contain; margin-left: 0.5mm;" />
        <div style="margin-left: 2mm; display: flex; flex-direction: column; justify-content: center; overflow: hidden; width: 10mm;">
            <h1 style="margin: 0 0 2px 0; font-family: sans-serif; font-size: 9pt; font-weight: bold; color: black; line-height: 1;">@AssetToPrint.AssetTag</h1>
            <p style="margin: 0; font-family: sans-serif; font-size: 6pt; color: black; line-height: 1.1; word-wrap: break-word; font-weight: 500;">@AssetToPrint.MakeModel</p>
        </div>
    </div>
}

@code {
    [Inject] private ItAssets.Services.FileStorageService FileStorage { get; set; } = default!;

    private List<Asset>? AllAssets;
    private List<Asset>? FilteredAssets;
    private List<ApplicationUser>? AllUsers;
    private List<Branch>? AllBranches;
    private List<Department>? AllDepartments;

    [SupplyParameterFromQuery(Name = "search")]
    public string? SearchQueryParam { get; set; }

    private string SearchQuery = "";
    private Asset? SelectedAsset;
    private Asset? NewAsset;
    private string NewAssetSpecs = "";
    private string NewAssetTeamViewer = "";
    private string NewAssetAnyDesk = "";
    private string MaintenanceNote = "";
    private IReadOnlyList<IBrowserFile> uploadedFiles = new List<IBrowserFile>();

    protected override async Task OnInitializedAsync()
    {
        if (!string.IsNullOrWhiteSpace(SearchQueryParam))
        {
            SearchQuery = SearchQueryParam;
        }
        await LoadAssets();
    }

    private async Task LoadAssets()
    {
        AllAssets = await DbContext.Assets
            .Include(a => a.User)
            .Include(a => a.Documents)
            .OrderByDescending(a => a.Id)
            .ToListAsync();
        
        AllUsers = await DbContext.Users.ToListAsync();
        AllBranches = await DbContext.Branches.ToListAsync();
        AllDepartments = await DbContext.Departments.ToListAsync();
        
        FilterAssets();
    }

    private void FilterAssets()
    {
        if (AllAssets == null) return;

        if (string.IsNullOrWhiteSpace(SearchQuery))
        {
            FilteredAssets = AllAssets;
        }
        else
        {
            var q = SearchQuery.ToLower();
            FilteredAssets = AllAssets.Where(a => 
                a.AssetTag.ToLower().Contains(q) || 
                a.IpAddress.ToLower().Contains(q) || 
                (a.User != null && a.User.Name.ToLower().Contains(q))
            ).ToList();
        }
    }

    private string ExtractDetail(string json, string key)
    {
        try
        {
            if (string.IsNullOrWhiteSpace(json)) return "";
            using var doc = System.Text.Json.JsonDocument.Parse(json);
            if (doc.RootElement.TryGetProperty(key, out var prop))
            {
                return prop.GetString() ?? "";
            }
        }
        catch { }
        return "";
    }

    private string GetStatusBadgeClass(string status)
    {
        return status switch
        {
            "Active" => "bg-success",
            "In Repair" => "bg-warning text-dark",
            "Decommissioned" => "bg-danger",
            _ => "bg-secondary"
        };
    }

    private string SelectedAssetSpecs = "";
    private string SelectedAssetTeamViewer = "";
    private string SelectedAssetAnyDesk = "";

    private void OpenModal(Asset asset)
    {
        SelectedAsset = asset;
        SelectedAssetSpecs = ExtractDetail(asset.Details, "Specs");
        SelectedAssetTeamViewer = ExtractDetail(asset.Details, "TeamViewerId");
        SelectedAssetAnyDesk = ExtractDetail(asset.Details, "AnyDeskId");
    }

    private void CloseModal()
    {
        SelectedAsset = null;
        uploadedFiles = new List<IBrowserFile>();
    }

    private async Task OpenAddModal()
    {
        string nextTag = "AST-0001";
        
        var astAssets = await DbContext.Assets
            .Where(a => a.AssetTag.StartsWith("AST-"))
            .ToListAsync();
            
        if (astAssets.Any())
        {
            int maxNumber = 0;
            foreach(var a in astAssets)
            {
                if (a.AssetTag.Length >= 8 && int.TryParse(a.AssetTag.Substring(4), out int num))
                {
                    if (num > maxNumber) maxNumber = num;
                }
            }
            if (maxNumber > 0)
            {
                nextTag = $"AST-{(maxNumber + 1):D4}";
            }
        }
        
        NewAsset = new Asset { Status = "Active", AssetTag = nextTag };
    }

    private void CloseAddModal()
    {
        NewAsset = null;
        uploadedFiles = new List<IBrowserFile>();
    }

    private Asset? AssetToPrint;
    private string QRBase64 = "";

    private void OpenPrintModal(Asset asset)
    {
        AssetToPrint = asset;
        var appUrl = NavManager.ToAbsoluteUri($"/assets?search={asset.AssetTag}").ToString();
        var qrContent = $"Asset Tag: {asset.AssetTag}\nURL: {appUrl}";
        QRBase64 = GenerateQRCodeBase64(qrContent);
    }

    private void ClosePrintModal()
    {
        AssetToPrint = null;
        QRBase64 = "";
    }

    private string GenerateQRCodeBase64(string text)
    {
        using QRCodeGenerator qrGenerator = new QRCodeGenerator();
        using QRCodeData qrCodeData = qrGenerator.CreateQrCode(text, QRCodeGenerator.ECCLevel.Q);
        using PngByteQRCode qrCode = new PngByteQRCode(qrCodeData);
        byte[] qrCodeImage = qrCode.GetGraphic(20);
        return Convert.ToBase64String(qrCodeImage);
    }

    private async Task SaveNewAsset()
    {
        if (NewAsset != null && !string.IsNullOrWhiteSpace(NewAsset.AssetTag))
        {
            if (!string.IsNullOrWhiteSpace(NewAssetSpecs) || !string.IsNullOrWhiteSpace(NewAssetTeamViewer) || !string.IsNullOrWhiteSpace(NewAssetAnyDesk))
            {
                NewAsset.Details = System.Text.Json.JsonSerializer.Serialize(new 
                { 
                    Specs = NewAssetSpecs,
                    TeamViewerId = NewAssetTeamViewer,
                    AnyDeskId = NewAssetAnyDesk
                });
            }

            DbContext.Assets.Add(NewAsset);
            await DbContext.SaveChangesAsync();
            
            if (uploadedFiles.Any())
            {
                var maxAllowedSize = 10 * 1024 * 1024; // 10 MB
                foreach(var file in uploadedFiles)
                {
                    if (file.Size <= maxAllowedSize)
                    {
                        try
                        {
                            var relativePath = await FileStorage.SaveFileAsync(file);
                            DbContext.AssetDocuments.Add(new AssetDocument
                            {
                                AssetId = NewAsset.Id,
                                FileName = file.Name,
                                FilePath = relativePath,
                                DocumentType = "Document"
                            });
                        }
                        catch { }
                    }
                }
                await DbContext.SaveChangesAsync();
            }

            await LoadAssets();
            NewAsset = null;
            NewAssetSpecs = "";
            NewAssetTeamViewer = "";
            NewAssetAnyDesk = "";
            uploadedFiles = new List<IBrowserFile>();
        }
    }

    private void LoadFiles(InputFileChangeEventArgs e)
    {
        uploadedFiles = e.GetMultipleFiles(10);
    }

    private async Task DeleteDocument(AssetDocument doc)
    {
        DbContext.AssetDocuments.Remove(doc);
        await DbContext.SaveChangesAsync();
        SelectedAsset?.Documents.Remove(doc);
    }

    private async Task SaveChanges()
    {
        if (SelectedAsset != null)
        {
            if (!string.IsNullOrWhiteSpace(SelectedAssetSpecs) || !string.IsNullOrWhiteSpace(SelectedAssetTeamViewer) || !string.IsNullOrWhiteSpace(SelectedAssetAnyDesk))
            {
                SelectedAsset.Details = System.Text.Json.JsonSerializer.Serialize(new 
                { 
                    Specs = SelectedAssetSpecs,
                    TeamViewerId = SelectedAssetTeamViewer,
                    AnyDeskId = SelectedAssetAnyDesk
                });
            }

            DbContext.Assets.Update(SelectedAsset);
            
            if (SelectedAsset.Status == "In Repair" && !string.IsNullOrWhiteSpace(MaintenanceNote))
            {
                DbContext.MaintenanceLogs.Add(new MaintenanceLog
                {
                    AssetId = SelectedAsset.Id,
                    IssueDescription = MaintenanceNote,
                    Status = "Open"
                });
                MaintenanceNote = "";
            }

            await DbContext.SaveChangesAsync();

            if (uploadedFiles.Any())
            {
                var maxAllowedSize = 10 * 1024 * 1024; // 10 MB
                foreach(var file in uploadedFiles)
                {
                    if (file.Size <= maxAllowedSize)
                    {
                        try
                        {
                            var relativePath = await FileStorage.SaveFileAsync(file);
                            DbContext.AssetDocuments.Add(new AssetDocument
                            {
                                AssetId = SelectedAsset.Id,
                                FileName = file.Name,
                                FilePath = relativePath,
                                DocumentType = "Document"
                            });
                        }
                        catch { }
                    }
                }
                await DbContext.SaveChangesAsync();
                uploadedFiles = new List<IBrowserFile>();
            }

            await LoadAssets();
            SelectedAsset = null;
        }
    }
}
