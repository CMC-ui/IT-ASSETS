@page "/"
@page "/assets"
@rendermode InteractiveServer
@using ItAssets.Data
@using ItAssets.Models
@using Microsoft.EntityFrameworkCore
@using QRCoder
@inject ApplicationDbContext DbContext
@inject NavigationManager NavManager

<PageTitle>Assets</PageTitle>

<div class="card shadow-sm">
    <div class="card-body">
        <div class="row mb-3">
            <div class="col-md-4">
                <input type="text" class="form-control" placeholder="Search by Asset Tag, IP, or User..." @bind="SearchQuery" @bind:event="oninput" @onkeyup="FilterAssets" />
            </div>
            <div class="col-md-8 text-end">
                <button class="btn btn-primary shadow-sm" @onclick="OpenAddModal">
                    <i class="bi bi-plus-circle"></i> Add Asset
                </button>
            </div>
        </div>

        <div class="table-responsive">
            <table class="table table-hover align-middle">
                <thead style="background-color: var(--bs-tertiary-bg); color: var(--bs-primary);">
                    <tr>
                        <th>Asset Tag</th>
                        <th>Type</th>
                        <th>Make/Model</th>
                        <th>MAC Address</th>
                        <th>IP Address</th>
                        <th>Branch</th>
                        <th>Dept</th>
                        <th>Price</th>
                        <th>Warranty</th>
                        <th>Specs</th>
                        <th>TeamViewer</th>
                        <th>AnyDesk</th>
                        <th>User</th>
                        <th>Status</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @if (FilteredAssets == null)
                    {
                        <tr><td colspan="15" class="text-center">Loading...</td></tr>
                    }
                    else if (!FilteredAssets.Any())
                    {
                        <tr><td colspan="15" class="text-center">No assets found.</td></tr>
                    }
                    else
                    {
                        @foreach (var asset in FilteredAssets)
                        {
                            <tr>
                                <td><strong>@asset.AssetTag</strong></td>
                                <td>@asset.DeviceType</td>
                                <td>@asset.MakeModel</td>
                                <td>@asset.MacAddress</td>
                                <td>@asset.IpAddress</td>
                                <td>@asset.Branch?.Name</td>
                                <td>@asset.Department?.Name</td>
                                <td>@asset.PurchasePrice.ToString("C")</td>
                                <td>@asset.WarrantyExpiration?.ToString("yyyy-MM-dd")</td>
                                <td>@ExtractDetail(asset.Details, "Specs")</td>
                                <td>@ExtractDetail(asset.Details, "TeamViewerId")</td>
                                <td>@ExtractDetail(asset.Details, "AnyDeskId")</td>
                                <td>@asset.User?.Name</td>
                                <td>
                                    <span class="badge @GetStatusBadgeClass(asset.Status)">@asset.Status</span>
                                </td>
                                <td>
                                    <button class="btn btn-sm btn-outline-primary me-1" @onclick="() => OpenModal(asset)">
                                        <i class="bi bi-pencil"></i> Manage
                                    </button>
                                    <button class="btn btn-sm btn-outline-secondary" @onclick="() => OpenPrintModal(asset)">
                                        <i class="bi bi-printer"></i> Print QR
                                    </button>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@if (SelectedAsset != null)
{
    <!-- Quick Manage Modal -->
    <div class="modal fade show d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.5);">
        <div class="modal-dialog modal-lg">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Manage Asset @SelectedAsset.AssetTag</h5>
                    <button type="button" class="btn-close" @onclick="CloseModal"></button>
                </div>
                <div class="modal-body">
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Asset Tag <span class="text-muted">(Auto-generated)</span></label>
                            <input type="text" class="form-control" @bind="SelectedAsset.AssetTag" readonly disabled />
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Device Type</label>
                            <input type="text" class="form-control" @bind="SelectedAsset.DeviceType" />
                        </div>
                    </div>
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Make/Model</label>
                            <input type="text" class="form-control" @bind="SelectedAsset.MakeModel" />
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Status</label>
                            <select class="form-select" @bind="SelectedAsset.Status">
                                <option value="Active">Active</option>
                                <option value="In Repair">In Repair</option>
                                <option value="Decommissioned">Decommissioned</option>
                            </select>
                        </div>
                    </div>
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label">MAC Address</label>
                            <input type="text" class="form-control" @bind="SelectedAsset.MacAddress" />
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label">IP Address</label>
                            <input type="text" class="form-control" @bind="SelectedAsset.IpAddress" />
                        </div>
                    </div>
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Branch</label>
                            <select class="form-select" @bind="SelectedAsset.BranchId">
                                <option value="">-- Select Branch --</option>
                                @if (AllBranches != null)
                                {
                                    @foreach (var b in AllBranches)
                                    {
                                        <option value="@b.Id">@b.Name</option>
                                    }
                                }
                            </select>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Department</label>
                            <select class="form-select" @bind="SelectedAsset.DepartmentId">
                                <option value="">-- Select Department --</option>
                                @if (AllDepartments != null)
                                {
                                    @foreach (var d in AllDepartments)
                                    {
                                        <option value="@d.Id">@d.Name</option>
                                    }
                                }
                            </select>
                        </div>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Assigned User</label>
                        <select class="form-select" @bind="SelectedAsset.UserId">
                            <option value="">-- Unassigned --</option>
                            @if (AllUsers != null)
                            {
                                @foreach (var user in AllUsers)
                                {
                                    <option value="@user.Id">@user.Name (@user.Email)</option>
                                }
                            }
                        </select>
                    </div>
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Purchase Price</label>
                            <div class="input-group">
                                <span class="input-group-text">$</span>
                                <input type="number" step="0.01" class="form-control" @bind="SelectedAsset.PurchasePrice" />
                            </div>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Warranty Expiration</label>
                            <input type="date" class="form-control" @bind="SelectedAsset.WarrantyExpiration" />
                        </div>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Hardware Specs</label>
                        <textarea class="form-control" rows="2" placeholder="e.g. 16GB RAM, 512GB SSD, i7 CPU" @bind="SelectedAssetSpecs"></textarea>
                    </div>
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label">TeamViewer ID</label>
                            <input type="text" class="form-control" @bind="SelectedAssetTeamViewer" />
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label">AnyDesk ID</label>
                            <input type="text" class="form-control" @bind="SelectedAssetAnyDesk" />
                        </div>
                    </div>
                    
                    @if (SelectedAsset.Status == "In Repair")
                    {
                        <div class="mb-3">
                            <label class="form-label text-warning"><i class="bi bi-exclamation-triangle"></i> Maintenance Note</label>
                            <textarea class="form-control" @bind="MaintenanceNote" placeholder="Describe the issue..."></textarea>
                        </div>
                    }
                    <div class="mb-3">
                        <label class="form-label">Upload Documents/Images (Max 10MB each)</label>
                        <InputFile OnChange="@LoadFiles" class="form-control" accept=".pdf,.png,.jpg,.jpeg" multiple />
                        @if (uploadedFiles.Any())
                        {
                            <small class="text-success d-block mt-1">Ready to upload @uploadedFiles.Count files</small>
                        }
                        
                        @if (SelectedAsset.Documents != null && SelectedAsset.Documents.Any())
                        {
                            <div class="row mt-4">
                                @foreach (var doc in SelectedAsset.Documents.ToList())
                                {
                                    <div class="col-md-6 mb-3 position-relative">
                                        <div class="d-flex justify-content-between align-items-center mb-1">
                                            <label class="form-label text-muted fw-bold mb-0 text-truncate" style="max-width: 80%;">@doc.FileName</label>
                                            <button type="button" class="btn btn-sm btn-outline-danger" @onclick="() => DeleteDocument(doc)">
                                                <i class="bi bi-trash"></i>
                                            </button>
                                        </div>
                                        @if (doc.FilePath.EndsWith(".pdf", StringComparison.OrdinalIgnoreCase))
                                        {
                                            <embed src="/uploads/@doc.FilePath" type="application/pdf" width="100%" height="250px" class="border rounded shadow-sm" />
                                        }
                                        else
                                        {
                                            <div class="bg-body-secondary border rounded shadow-sm p-2 d-flex align-items-center justify-content-center" style="height: 250px;">
                                                <img src="/uploads/@doc.FilePath" class="img-fluid rounded" style="max-height: 100%; object-fit: contain;" />
                                            </div>
                                        }
                                    </div>
                                }
                            </div>
                        }
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" @onclick="CloseModal">Close</button>
                    <button type="button" class="btn btn-primary" @onclick="SaveChanges">Save changes</button>
                </div>
            </div>
        </div>
    </div>
}

